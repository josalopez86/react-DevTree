{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir":"./src",
        "lib": ["ESNext"],
        "target":"ESNext",
        "moduleResolution": "nodenext",
        "module":"nodenext",
        "strict": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "declaration": true
    },
    "include": ["src/**/*.ts"]
}